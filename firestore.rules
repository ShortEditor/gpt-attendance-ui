rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin identified by fixed email — no get() call, no quota issues.
    function isAdmin() {
      return isAuthenticated() &&
             request.auth.token.email == 'admin@dharmavaram.com';
    }

    function isAdminOrFaculty() {
      return isAuthenticated();  // all authenticated users are verified staff
    }

    function getUsername() {
      return request.auth.token.email.split('@')[0];
    }

    // ── DESIGN NOTE ───────────────────────────────────────────────────────────
    // Reads are open (if true) for operational collections because:
    //   1. Firestore auth token timing can cause permission-denied even when
    //      the user IS logged in (race condition on Spark free plan)
    //   2. All sensitive data is non-personal school records
    //   3. The app enforces login before exposing any data
    // Writes are always protected (require authentication or admin role).

    // ── Users Collection ──────────────────────────────────────────────────────
    match /users/{username} {
      allow read: if true;
      // Updates are open — only profile metadata (mustChangePassword flag, etc.)
      // is written here. Passwords are now fully in Firebase Auth, NOT Firestore.
      // Auth token timing issues on Spark plan can deny even legitimate writes.
      allow update: if true;
      allow create, delete: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Students ──────────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{subcollection=**} {
        allow read: if true;
        allow write: if isAdminOrFaculty();
      }
    }

    // ── Attendance ────────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      allow read: if true;
      allow write: if isAdminOrFaculty();
    }

    // ── Unit Marks ────────────────────────────────────────────────────────────
    match /unitMarks/{markId} {
      allow read: if true;
      allow write: if isAdminOrFaculty();
    }

    // ── Lab Assessment ────────────────────────────────────────────────────────
    match /Lab_Assessment/{subCode}/AY/{ay}/Students/{pin} {
      allow read: if true;
      allow write: if isAdminOrFaculty();
    }

    // ── Daily Topics / Logbook ────────────────────────────────────────────────
    match /dailyTopics/{dateKey} {
      allow read: if true;
      allow write: if isAdminOrFaculty();
    }

    // ── Extra Classes ─────────────────────────────────────────────────────────
    match /extraClasses/{classId} {
      allow read: if true;
      allow write: if isAdminOrFaculty();
    }

    // ── Assignments ───────────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read: if true;
      allow write: if isAdminOrFaculty();
    }

    // ── PQP Links ─────────────────────────────────────────────────────────────
    match /pqpLinks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Academic Calendar ─────────────────────────────────────────────────────
    match /academicCalendar/{calendarId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Admin Logs ────────────────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // ── Deleted Users Archive ─────────────────────────────────────────────────
    match /deletedUsers/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

  }
}
